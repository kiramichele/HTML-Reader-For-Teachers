# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API)

# Project URL, e.g. https://abcdxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / public key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (SERVER ONLY — never expose to the browser).
# Used to save student responses (students have no login) and to load
# public activities on the player page.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (SERVER ONLY) — enables "Generate with Claude".
# Optional: leave blank to disable AI generation (upload still works).
# Get one at https://console.anthropic.com/ . You pay per generation.
ANTHROPIC_API_KEY=

# Stripe (SERVER ONLY) — enables the $10/month subscription that gates AI
# generation after each teacher's free-generation trial. Leave all three blank to
# disable billing entirely (generation stays open; trial is informational only).
STRIPE_SECRET_KEY=
# The recurring $10/month Price id you create in the Stripe dashboard (price_...).
STRIPE_PRICE_ID=
# Signing secret of the /api/stripe/webhook endpoint you create (whsec_...).
STRIPE_WEBHOOK_SECRET=
